{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@components/*": ["src/components/*"],
  "@services/*": ["src/services/*"],
  "@utils/*": ["src/utils/*"],
  "@store/*": ["src/store/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
, "api/auth.api.ts", "api/client.js"  ]
}
